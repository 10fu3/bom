func DeleteMany{{ .ModelName }}(ctx context.Context, db bom.Querier, q {{ .ModelName }}DeleteMany) (int64, error) {
  d := {{ $.DialectInit }}
  state := newArgState(d)
  whereClause := build{{ .ModelName }}Where(d, "t0", state, q.Where)
  if err := ensureParamLimit(d, len(state.Args())); err != nil {
    return 0, err
  }
  sqlStr := fmt.Sprintf("DELETE FROM %s", d.QuoteIdent("{{ .TableName }}"))
  if whereClause != "" {
    sqlStr += " WHERE " + whereClause
  }
  res, err := db.ExecContext(ctx, sqlStr, state.Args()...)
  if err != nil {
    return 0, err
  }
  return res.RowsAffected()
}

