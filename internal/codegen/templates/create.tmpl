{{ define "create" }}
{{ range .Tables }}
{{- if .UniqueConstraints }}
{{- $model := .ModelName }}
{{- $table := .TableName }}

type {{ .ModelName }}CreateData struct {
	{{- range .Columns }}
	{{ .Camel }} opt.Opt[{{ .GoType }}]
	{{- end }}
	{{- range .Relations }}
	{{- if eq .Kind "HasMany" }}
	{{ .FieldName }} []{{ .TargetModel }}CreateData
	{{- else if eq .Kind "HasOne" }}
	{{ .FieldName }} *{{ .TargetModel }}CreateData
	{{- end }}
	{{- end }}
}

type {{ .ModelName }}Create struct {
	Data   {{ .ModelName }}CreateData
	Select {{ .ModelName }}Select
}

type {{ .ModelName }}CreateMany struct {
	Data []{{ .ModelName }}CreateData
}

func CreateOne{{ .ModelName }}[T {{ .ModelName }}Model](ctx context.Context, db bom.Querier, q {{ .ModelName }}Create) (*T, error) {
	d := {{ $.DialectInit }}
	data := q.Data
	if err := create{{ .ModelName }}Record(ctx, db, d, &data); err != nil {
		return nil, err
	}
	if err := create{{ .ModelName }}Relations(ctx, db, d, &data); err != nil {
		return nil, err
	}
	var fetch func(context.Context, {{ .ModelName }}Select) (*T, error)
	{{- range .UniqueConstraints }}
	if fetch == nil {
		if ({{- $first := true -}}{{- range .Fields -}}{{- if not $first }} && {{ end -}}data.{{ .Camel }}.IsSome(){{- $first = false -}}{{- end }}) {
			lookup := {{ .TypeName }}{
				{{- range .Fields }}
				{{ .Camel }}: data.{{ .Camel }}.Value(),
				{{- end }}
			}
			fetch = func(ctx context.Context, sel {{ $model }}Select) (*T, error) {
				return FindUnique{{ $model }}[T](ctx, db, {{ $model }}FindUnique[{{ .TypeName }}]{
					Where:  lookup,
					Select: sel,
				})
			}
		}
	}
	{{- end }}
	if fetch == nil {
		return nil, fmt.Errorf("{{ .ModelName }}Create requires values for a unique constraint")
	}
	return fetch(ctx, q.Select)
}

func CreateMany{{ .ModelName }}(ctx context.Context, db bom.Querier, q {{ .ModelName }}CreateMany) (int64, error) {
	d := {{ $.DialectInit }}
	if len(q.Data) == 0 {
		return 0, nil
	}
	var total int64
	for i := range q.Data {
		data := q.Data[i]
		if err := create{{ .ModelName }}Record(ctx, db, d, &data); err != nil {
			return total, err
		}
		if err := create{{ .ModelName }}Relations(ctx, db, d, &data); err != nil {
			return total, err
		}
		total++
	}
	return total, nil
}

func create{{ .ModelName }}Record(ctx context.Context, db bom.Querier, d dialect.Dialect, data *{{ .ModelName }}CreateData) error {
	state := newArgState(d)
	var columns []string
	var placeholders []string
	if identityGenerator == nil {
		identityGenerator = &bom.DefaultIdentityGenerator{}
	}
	{{- range .Columns }}
	var wantsAuto{{ .Camel }} bool
	{{- end }}
	{{- range .Columns }}
	if data.{{ .Camel }}.IsSome() {
		val := data.{{ .Camel }}.Value()
		columns = append(columns, "{{ .Name }}")
		placeholders = append(placeholders, state.Add(val))
	} else {
		{{- if .Identity }}
		{{- if ne .GoType "string" }}
		return fmt.Errorf("identity strategy requires string column {{ .Name }}")
		{{- end }}
		genVal, err := identityGenerator.Generate("{{ .Identity }}")
		if err != nil {
			return err
		}
		data.{{ .Camel }} = opt.OVal(genVal)
		columns = append(columns, "{{ .Name }}")
		placeholders = append(placeholders, state.Add(genVal))
		{{- else if .AutoIncrement }}
		wantsAuto{{ .Camel }} = true
		{{- end }}
	}
	{{- end }}
	if err := ensureParamLimit(d, len(state.Args())); err != nil {
		return err
	}
	insertInput := planner.InsertInput{
		Table:   "{{ $table }}",
		Columns: columns,
		Values:  placeholders,
	}
	autoCount := 0
	{{- range .Columns }}
	if wantsAuto{{ .Camel }} {
		autoCount++
	}
	{{- end }}
	var returning bool
	if d.Cap().InsertReturning && autoCount > 0 {
		returning = true
		var returningCols []string
		{{- range .Columns }}
		if wantsAuto{{ .Camel }} {
			returningCols = append(returningCols, "{{ .Name }}")
		}
		{{- end }}
		if len(returningCols) > 0 {
			insertInput.Returning = returningCols
		}
	}
	sqlStr, err := planner.BuildInsert(d, insertInput)
	if err != nil {
		return err
	}
	if returning {
		rows, err := db.QueryContext(ctx, sqlStr, state.Args()...)
		if err != nil {
			return err
		}
		defer rows.Close()
		var scanTargets []any
		{{- range .Columns }}
		var ret{{ .Camel }} {{ .GoType }}
		if wantsAuto{{ .Camel }} {
			scanTargets = append(scanTargets, &ret{{ .Camel }})
		}
		{{- end }}
		if !rows.Next() {
			if err := rows.Err(); err != nil {
				return err
			}
			return fmt.Errorf("{{ .ModelName }} insert returned no rows")
		}
		if err := rows.Scan(scanTargets...); err != nil {
			return err
		}
		{{- range .Columns }}
		if wantsAuto{{ .Camel }} {
			data.{{ .Camel }} = opt.OVal(ret{{ .Camel }})
		}
		{{- end }}
		return nil
	}
	res, err := db.ExecContext(ctx, sqlStr, state.Args()...)
	if err != nil {
		return err
	}
	if autoCount == 1 {
		id, err := res.LastInsertId()
		if err != nil {
			return err
		}
		{{- range .Columns }}
		if wantsAuto{{ .Camel }} {
			data.{{ .Camel }} = opt.OVal({{ castInt64 .GoType "id" }})
		}
		{{- end }}
	} else if autoCount > 1 {
		return fmt.Errorf("%s cannot populate multiple auto columns for {{ .TableName }} without RETURNING", d.Name())
	}
	return nil
}

func create{{ .ModelName }}Relations(ctx context.Context, db bom.Querier, d dialect.Dialect, data *{{ .ModelName }}CreateData) error {
	{{- range .Relations }}
	{{- if eq .Kind "HasMany" }}
	if len(data.{{ .FieldName }}) > 0 {
		for i := range data.{{ .FieldName }} {
			child := &data.{{ .FieldName }}[i]
			{{- $rel := . -}}
			{{- range $idx, $fk := $rel.ForeignKeys }}
			if !child.{{ camel $fk }}.IsSome() {
				if !data.{{ camel (index $rel.LocalKeys $idx) }}.IsSome() {
					return fmt.Errorf("{{ $model }}: missing {{ index $rel.LocalKeys $idx }} for relation {{ $rel.FieldName }}")
				}
				child.{{ camel $fk }} = data.{{ camel (index $rel.LocalKeys $idx) }}
			}
			{{- end }}
			{{- range $rel.InheritedKeys }}
			if !child.{{ .ChildField }}.IsSome() && data.{{ .ParentField }}.IsSome() {
				child.{{ .ChildField }} = data.{{ .ParentField }}
			}
			{{- end }}
			if err := create{{ .TargetModel }}Record(ctx, db, d, child); err != nil {
				return err
			}
			if err := create{{ .TargetModel }}Relations(ctx, db, d, child); err != nil {
				return err
			}
		}
	}
	{{- else if eq .Kind "HasOne" }}
	if data.{{ .FieldName }} != nil {
		child := data.{{ .FieldName }}
		{{- $rel := . -}}
		{{- range $idx, $fk := $rel.ForeignKeys }}
		if !child.{{ camel $fk }}.IsSome() {
			if !data.{{ camel (index $rel.LocalKeys $idx) }}.IsSome() {
				return fmt.Errorf("{{ $model }}: missing {{ index $rel.LocalKeys $idx }} for relation {{ $rel.FieldName }}")
			}
			child.{{ camel $fk }} = data.{{ camel (index $rel.LocalKeys $idx) }}
		}
		{{- end }}
		{{- range $rel.InheritedKeys }}
		if !child.{{ .ChildField }}.IsSome() && data.{{ .ParentField }}.IsSome() {
			child.{{ .ChildField }} = data.{{ .ParentField }}
		}
		{{- end }}
		if err := create{{ .TargetModel }}Record(ctx, db, d, child); err != nil {
			return err
		}
		if err := create{{ .TargetModel }}Relations(ctx, db, d, child); err != nil {
			return err
		}
	}
	{{- end }}
	{{- end }}
	return nil
}
{{- end }}
{{ end }}
{{ end }}
