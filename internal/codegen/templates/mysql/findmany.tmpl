		}
		if len(raw) == 0 {
			raw = []byte("{}")
		}
		raw = normalizeJSONRaw(raw)
		var rec {{ .ModelName }}
		if err := json.Unmarshal(raw, &rec); err != nil {
			return nil, err
		}
		result = append(result, T(rec))
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}
	return result, nil
}

